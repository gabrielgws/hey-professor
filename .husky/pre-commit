PHP="/c/Users/gabri/.config/herd/bin/php84/php.exe"

echo "Rodando PHPStan..."

$PHP ./vendor/bin/phpstan
if [ $? -ne 0 ]; then
    echo "❌ Opa! Deu ruim aqui com PHPStan. Arrume antes de continuar..."
    exit 1
fi

echo "Rodando testes..."

$PHP artisan test --parallel
if [ $? -ne 0 ]; then
    echo "❌ Opa! Deu ruim aqui com algum teste. Arrume antes de continuar..."
    exit 1
fi

echo "Formatando arquivos com Laravel Pint..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.php$") || true

for FILE in $STAGED_FILES
do
    $PHP ./vendor/bin/pint "$FILE" > /dev/null 2>&1
    git add "$FILE"
done

echo "✅ Pre-commit passou!"

exit 0
